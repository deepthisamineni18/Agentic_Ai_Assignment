# Copy this file to `.env` (same folder as docker-compose.yml) and fill in
# a real key to enable live LLM calls in the Annotator/QualityAssessor
# agents and the RAG chat. docker-compose automatically loads a `.env` file
# from this directory for variable substitution — no shell `export` needed.
#
# Leave both unset (or leave this as .env.example, not .env) and every
# pipeline still runs end-to-end offline using template/keyword fallbacks.
# The active-learning pipeline's CLI output will say
# "Annotator LLM: offline keyword fallback (no API key set)" in that case.

# Optional Tavily live search API key; when set, RAG search may query the web.
TAVILY_API_KEY=

ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-5
# ANTHROPIC_MODEL=claude-sonnet-5

# Alternative provider (used instead of Anthropic if set)
# GROQ_API_KEY=
